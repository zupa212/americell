# ─────────────────────────────────────────────────────────────
# Americell — environment variables. Copy to .env.local and fill in.
# ─────────────────────────────────────────────────────────────

# ── Auth.js (next-auth v5) ──────────────────────────────────
# Required. Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-long-random-string
# Optional; set to your public site URL in production.
# AUTH_URL=http://localhost:3000

# ── Database (Postgres — Supabase or Neon) ─────────────────
# App runtime: use the TRANSACTION pooler (port 6543). postgres.js is set with
# prepare:false so pgBouncer transaction mode works.
DATABASE_URL=postgresql://user:password@host:6543/postgres
# Migrations (drizzle-kit): use the DIRECT / session pooler (port 5432).
DIRECT_URL=postgresql://user:password@host:5432/postgres

# ── Stripe (Phase 4 — not required yet) ─────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# CHECKOUT_SUCCESS_URL=http://localhost:3000/dashboard?checkout=success
# CHECKOUT_CANCEL_URL=http://localhost:3000/#pricing
# Optional per-device price IDs, e.g. PRICE_PIXEL8_MONTHLY=price_...

# ── CellGods Reseller API (the real phone backend) ──────────
# SECRET — server-only, never commit the real value. From your reseller dashboard.
CELLGODS_API_KEY=cg_reseller_your_key_here
CELLGODS_API_BASE=https://api.cellgods.com/api/reseller

# ── Reseller / admin config ─────────────────────────────────
# Comma-separated emails that may access the /admin reseller cockpit.
ADMIN_EMAILS=you@example.com
# Retail markup over wholesale — SERVER-ONLY (not NEXT_PUBLIC; would leak wholesale cost).
RESELLER_MARGIN_PCT=50
RESELLER_MARGIN_MIN_CENTS=500

# ── Security / ops ──────────────────────────────────────────
# AES-256-GCM key for encrypting rental PINs at rest. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PIN_ENCRYPTION_KEY=replace-with-32-byte-base64
# Protects /api/cron/* endpoints.
CRON_SECRET=replace-with-random

# ── Public ──────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Crypto payments (all optional — each shows in the "Pay with crypto" picker
#    only when its key is present; unconfigured ones render as "Demo") ─────────
#
# MoonPay — card/bank → crypto. Requires customer KYC.
# MOONPAY_PUBLISHABLE_KEY=pk_test_...
# MOONPAY_SECRET_KEY=sk_test_...
# MOONPAY_WEBHOOK_KEY=wk_test_...
# MOONPAY_WALLET_ADDRESS=0xYourWallet        # where you receive the crypto
# MOONPAY_CURRENCY_CODE=usdc                 # crypto to receive (e.g. usdc)
# MOONPAY_MODE=sandbox                       # sandbox | production
#
# NOWPayments — non-custodial gateway, 100+ coins, NO customer KYC. Funds forward
# to your payout wallet (set the wallet in the NOWPayments dashboard). The IPN
# secret signs webhooks (Store Settings → IPN). https://nowpayments.io
# NOWPAYMENTS_API_KEY=...
# NOWPAYMENTS_IPN_SECRET=...
#
# Coinbase Commerce — accept crypto directly, NO customer KYC to pay a charge.
# API key: Settings → Security → API keys. Webhook secret: Settings → Webhooks
# → "Shared secret". https://commerce.coinbase.com
# COINBASE_COMMERCE_API_KEY=...
# COINBASE_COMMERCE_WEBHOOK_SECRET=...
